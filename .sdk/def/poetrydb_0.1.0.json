          {
            "name": "outputFields",
            "in": "path",
            "required": true,
            "description": "Comma-separated list of output fields (author, title, lines, linecount, all)",
            "schema": {
              "type": "string"
            },
            "example": "author,title,linecount"
          },
          {
            "name": "format",
            "in": "path",
            "required": true,
            "description": "Output format (json or text)",
            "schema": {
              "type": "string",
              "enum": [
                "json",
                "text"
              ]
            },
            "example": "text"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              },
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          },
          "404": {
            "description": "No poems found",
            "content": {
              "application/json": {
