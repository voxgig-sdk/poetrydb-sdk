{
  "openapi": "3.0.3",
  "info": {
    "title": "PoetryDB API",
    "description": "An API for internet poets to access and retrieve poetry data. Users can search for poems by title, author, lines, line count, and more, and receive the results in JSON format.",
    "version": "1.0.0",
    "contact": {
      "url": "https://github.com/thundercomb/poetrydb"
    },
    "license": {
      "name": "GPL-2.0",
      "url": "https://github.com/thundercomb/poetrydb/blob/master/LICENSE.txt"
    }
  },
  "servers": [
    {
      "url": "https://poetrydb.org",
      "description": "Production server"
    }
  ],
  "paths": {
    "/author": {
      "get": {
        "summary": "Get all authors",
        "description": "Returns a list of all available authors in the database",
        "operationId": "getAllAuthors",
        "tags": [
          "Author"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "authors": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                },
                "example": {
                  "authors": [
                    "Adam Lindsay Gordon",
                    "Alan Seeger",
                    "Alexander Pope",
                    "William Shakespeare",
                    "William Wordsworth"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/author/{author}": {
      "get": {
        "summary": "Search poems by author",
        "description": "Returns poems by the specified author (partial match by default)",
        "operationId": "searchByAuthor",
        "tags": [
          "Author"
        ],
        "parameters": [
          {
            "name": "author",
            "in": "path",
            "required": true,
            "description": "The name or part of the name of the author",
            "schema": {
              "type": "string"
            },
            "example": "Ernest Dowson"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Poem"
                  }
                }
              }
            }
          },
          "404": {
            "description": "No poems found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/author/{author}:abs": {
      "get": {
        "summary": "Search poems by exact author name",
        "description": "Returns poems by the specified author (exact match)",
        "operationId": "searchByAuthorExact",
        "tags": [
          "Author"
        ],
        "parameters": [
          {
            "name": "author",
            "in": "path",
            "required": true,
            "description": "The exact name of the author",
            "schema": {
              "type": "string"
            },
            "example": "Ernest Dowson"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Poem"
                  }
                }
              }
            }
          },
          "404": {
            "description": "No poems found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/author/{author}/{outputFields}": {
      "get": {
        "summary": "Search poems by author with specific output fields",
        "description": "Returns specific fields from poems by the specified author",
        "operationId": "searchByAuthorWithFields",
        "tags": [
          "Author"
        ],
        "parameters": [
          {
            "name": "author",
            "in": "path",
            "required": true,
            "description": "The name or part of the name of the author",
            "schema": {
              "type": "string"
            },
            "example": "Ernest Dowson"
          },
          {
            "name": "outputFields",
            "in": "path",
            "required": true,
            "description": "Comma-separated list of output fields (author, title, lines, linecount, all)",
            "schema": {
              "type": "string"
            },
            "example": "author,title,linecount"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          },
          "404": {
            "description": "No poems found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    },
    "/author/{author}/{outputFields}.{format}": {
      "get": {
        "summary": "Search poems by author with specific output fields and format",
        "description": "Returns specific fields from poems by the specified author in the requested format",
        "operationId": "searchByAuthorWithFieldsAndFormat",
        "tags": [
          "Author"
        ],
        "parameters": [
          {
            "name": "author",
            "in": "path",
